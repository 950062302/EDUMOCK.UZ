{
  "note": "PocketBase v0.22.x does NOT allow importing/modifying the system 'users' collection via Import collections. Use this as a reference to manually add fields in Admin UI: Collections -> users -> New field.",
  "fields": [
    { "name": "first_name", "type": "text", "options": { "max": 120 } },
    { "name": "last_name", "type": "text", "options": { "max": 120 } },
    { "name": "bio", "type": "text", "options": { "max": 2000 } },
    { "name": "avatar_url", "type": "url", "options": {} },
    { "name": "role", "type": "select", "options": { "maxSelect": 1, "values": ["user", "developer"] } },
    { "name": "tariff_name", "type": "select", "options": { "maxSelect": 1, "values": ["Basic", "Premium"] } },
    { "name": "storage_limit_bytes", "type": "number", "options": { "noDecimal": true, "min": 0 } },
    { "name": "storage_used_bytes", "type": "number", "options": { "noDecimal": true, "min": 0 } }
  ]
}

